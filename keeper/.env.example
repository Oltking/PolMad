# --- required ---
# Deployed PropheyMarket on Monad testnet
PROPHEY_MARKET_ADDRESS=0x
# Private key of the wallet set as `resolver` on PropheyMarket.
# Use a throwaway testnet key. This key can resolve Calls — treat it as hot.
KEEPER_PRIVATE_KEY=0x

# --- optional ---
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
ETHEREUM_RPC_URL=
BASE_RPC_URL=

KEEPER_POLL_MS=30000
KEEPER_LOOKBACK_BLOCKS=5000

# Liquidity pools to watch for the LIQUIDITY_PULL trigger, comma-separated.
# Pools are never guessed — an unknown pool means that trigger simply doesn't fire.
# Per-target override wins over the default:
#   POOLS_0xABC...=0xpool1,0xpool2
DEFAULT_POOLS=
